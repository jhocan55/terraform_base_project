.env
.env.*
*.pem
*.key
*.crt

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db

# Logs
*.log

# Archives / temp
*.zip
*.tar
*.tar.gz
*.tgz

# Python virtual env (in case of helper scripts)
venv/
.envrc

# Node (if any tooling added later)
node_modules/
